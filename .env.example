# ── Inference backend ──────────────────────────────────────────────────────────
# "huggingface" → calls HuggingFace Inference API (no GPU needed, requires token)
# "local"       → runs model on your machine via MPS/CUDA/CPU (no token needed)
INFERENCE_BACKEND=huggingface

# ── HuggingFace API token ──────────────────────────────────────────────────────
# Required only when INFERENCE_BACKEND=huggingface
# Get a free token at https://huggingface.co/settings/tokens (Read access)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
